{
  "name": "pdf-renamer",
  "type": "module",
  "version": "0.9.0",
  "main": "main.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "devtools": "react-devtools",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "electron-builder",
    "clean": "rm -rf node_modules dist dist-electron package-lock.json"
  },
  "keywords": [],
  "author": "Croyd Crenson",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@fortawesome/fontawesome-free": "^7.0.0",
    "chokidar": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "react-devtools": "^6.1.5",
    "vite": "^5.3.3"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "snowcitizen",
        "repo": "pdf-renamer"
      }
    ],
    "appId": "com.yourcompany.pdfrenamer",
    "productName": "PDF Renamer",
    "files": [
      "**/*",
      "dist"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}